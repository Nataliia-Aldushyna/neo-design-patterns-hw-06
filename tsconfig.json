{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["node"],
    // "experimentalDecorators": true
    // Not required in TypeScript 6.x (new decorators syntax).
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
} 